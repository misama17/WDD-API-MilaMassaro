---
// @ts-nocheck
import TarotCards from "../../components/TarotCards.astro";
import MainLayout from "../../layouts/MainLayout.astro";

const resMeanings = await fetch('https://tarotapi.dev/api/v1/cards')
const tarotMeanings = await resMeanings.json()
---


<MainLayout>
    <h1>Overview of <em>all the cards</em> and their meaning</h1>
	<section>
        {tarotMeanings.cards.map( card => {
            return (
                <TarotCards image={`/assets/images/${card.name_short}.jpeg`} nameShort={card.name_short} nameCard={card.name} type={card.type} meaningUp={card.meaning_up} meaningRev={card.meaning_rev}/>
            )
        })}
	</section>
</MainLayout>

<style>
    @font-face {
		font-family: 'Instrument Serif Regular';
		src: url(./public/assets/fonts/InstrumentSerif-Regular.ttf);
		font-weight: 100 800;
		font-style: normal;
	}

	* {
		font-family: 'Instrument Serif Regular', serif;
  		color: #efe7d5;
	}

    h1 {
        text-align: center;
        margin: 1em;
        font-size: clamp(2em, 10vw, 4em);
    }

    section {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
		justify-content: center;
		align-items: center;
        gap: 2em;
    }
</style>