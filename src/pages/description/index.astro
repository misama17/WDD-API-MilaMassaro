---
// @ts-nocheck
import MainLayout from "../../layouts/MainLayout.astro";
import TarotCards from "../../components/TarotCards.astro";

const resMeanings = await fetch('https://tarotapi.dev/api/v1/cards')
const tarotMeanings = await resMeanings.json()
---


<MainLayout title="Ask the cards">

	<section class="saved-cards">
        
    </section>
	
</MainLayout>

<style>
    .saved-cards {
        display: grid;
        grid-template-areas: 
        "card1  text1"
        "card2  text2"
        "card3  text3";
    }


</style>

<style is:global>
    .tarotcard-outer {
        background: none;
        border: none;
        padding: 0;
        margin: 0;
        font: inherit;
        color: inherit;
        
        width: 12em;
        height: 21em;
        perspective: 20em;
        cursor: pointer;
        
        touch-action: none; 
        user-select: none;

        box-shadow: 
            0 2px 6px rgba(0,0,0,0.1),
            0 10px 20px rgba(0,0,0,0.1);
    }

    .tarotcard-inner {
        width: 100%;
        height: 100%;

        transition: transform 1s;
        transform-style: preserve-3d;
    }

    .tarotcard-front,
    .tarotcard-back {
        position: absolute;
        inset: 0;
        height: 100%;
        width: 100%;
        background: var(--color-bg);
        border: .35em solid var(--color-border-card);
        border-radius: .25em;
        color: var(--color-text-one);
        text-align: center;
        font-size: 30px;
        
        overflow: clip;
        box-sizing: border-box;
    }

    .tarotcard-front {
        /*  Zo weet je zeker dat hij ervoor komt, altijd goed om te doen.  */
        transform: translateZ(1px);

        & img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            box-sizing: border-box;
            pointer-events: none;
        }
    }

    .tarotcard-back {
        background: var(--color-border);
        color: var(--color-text-one);
        transform: rotateY( 180deg );

        & img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            box-sizing: border-box;
            transition: transform 1s cubic-bezier(0.34, 1.56, 0.64, 1);
            pointer-events: none;
        }
    }
</style>

<script>
    // @ts-nocheck
    // om het weer te lezen
	// JSON.parse(window.localStorage.getItem("chosen_cards"))

    const savedCards = JSON.parse(window.localStorage.getItem("chosen_cards"));
    const savedContainer = document.querySelector(".saved-cards");

    savedCards.forEach((cardName, i) => {
        const div = document.createElement("div");

        card.className = `tarotcard-outer card${i + 1}`;
        text.className = `tarot-text text${i + 1}`;

        div.className = "tarotcard-outer";
        div.setAttribute("aria-expanded", "false");

        const inner = document.createElement("div");
        inner.className = "tarotcard-inner";

        const front = document.createElement("div");
        front.className = "tarotcard-front";

        const imgFront = document.createElement("img");
        imgFront.src = "/assets/images/card-back.jpeg";
        imgFront.alt = "Tarot card back design";
        front.appendChild(imgFront);

        const back = document.createElement("div");
        back.className = "tarotcard-back";

        const imgBack = document.createElement("img");
        imgBack.src = `/assets/images/${cardName}.jpeg`;
        imgBack.alt = `Tarot card: ${cardName}`;
        back.appendChild(imgBack);

        inner.append(front, back);
        div.append(inner);

        savedContainer.appendChild(div);

        rotateSavedCards(inner);
    });

    function rotateSavedCards(cardInner) {
        cardInner.animate(
            [
            { transform: "rotateY(0deg)" },
            { transform: "rotateY(360deg)" }
            ],
            {
            duration: 30000,
            iterations: Infinity,
            easing: "linear"
            }
        );
    };
</script>