---
// import MainLayout from "../layouts/MainLayout.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import TarotCards from "../../components/TarotCards.astro";

const { title } = Astro.props;
const { image, nameShort } = Astro.props;

const resMeanings = await fetch('https://tarotapi.dev/api/v1/cards')
const tarotMeanings = await resMeanings.json()
---

<html>

	<!-- <MainLayout title="Tarot reading">
		<a href="/spread">Show spread animations</a>

		<section>
			{tarotMeanings.cards.map( card => {
				return (
					<TarotCards image={`/assets/images/${card.name_short}.jpeg`} nameShort={card.name_short}/>
				)
			})}
		</section>
	</MainLayout> -->

	<head>
		<title>{ title }</title>
	</head>
	<body>

	<main class="main-container">

		<h1>
			Drag and drop the cards to the dropzones
		</h1>
		
		<div class="dropzone-container">
			<div class="dropzone">past</div>
			<div class="dropzone">present</div>
			<div class="dropzone">future</div>
		</div>

		<div class="cards-container"></div>

		<style>
			:root {
				--color-bg: #4E2C5D;
				--color-border: #3b2146;
				--color-text-one: #fff;
				--color-hotzone: hotpink;
			}

			body {
				margin: 0;
				height: 100vh;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				align-items: center;

				background-color: var(--color-bg);
				color: var(--color-text-one);
			}

			.dropzone-container {
				display: flex;
				gap: 2em;
				margin-top: 10em;
			}

			.dropzone {
				width: 10em;
				height: 15em;
				border: 2px solid var(--color-border);
				border-radius: 10px;
				display: flex;
				align-items: center;
				justify-content: center;
				position: relative;
				transition: all 0.2s ease;
			}

			.dropzone.hot {
				border-color: hotpink;
				transform: scale(1.1);
			}

			.dropzone.full {
				border-color: white;
			}

			.cards-container {
				display: flex;
				gap: 2em;
				justify-content: center;
				position: absolute;
				bottom: 5em;
				width: 100%;
			}

			.tarot-deck {
				position: relative;
				width: 100vw;
				height: 15em;

				display: flex;
				justify-content: center;
				align-items: center;
			}

			.locked {
				cursor: default;
				opacity: 0.95;
			}

		</style>

		<style is:global>
			.card {
				width: 10em;
				height: 15em;
				border-radius: 10px;
				position: relative;
				transition: transform 0.2s ease;
				background-color: var(--color-bg);
				
				/* ChatGPT: belangrijk voor pointer events */
				touch-action: none;
				user-select: none;

			}


			/* MARK: Tarot Cards */
			.tarotcard-outer {
				background: none;
				border: none;
				padding: 0;
				margin: 0;
				font: inherit;
				color: inherit;
				
				position: absolute;
				top: 0;
				left: 0;
				width: 10em;
				height: 15em;
				perspective: 20em;
				cursor: pointer;
				
				touch-action: none; 
				user-select: none;
			}

			.tarotcard-inner {
				width: 100%;
				height: 100%;

				transition: transform 1s;
				transform-style: preserve-3d;
			}

			.tarotcard-front,
			.tarotcard-back {
				position: absolute;
				height: 100%;
				width: 100%;
				background: var(--color-bg);
				border: 2px solid var(--color-hotzone);
				color: var(--color-text-one);
				text-align: center;
				font-size: 30px;
				
				border-radius: 7px;
				
				backface-visibility: hidden;
			}

			.tarotcard-outer:not(.locked) .tarotcard-inner:hover {
				transform: translateY(-40px);
			}

			.tarotcard-front {
				/*  Zo weet je zeker dat hij ervoor komt, altijd goed om te doen.  */
				transform: translateZ(1px)
			}

			.tarotcard-back {
				background: var(--color-border);
				color: var(--color-text-one);
				transform: rotateY( 180deg );
			}

			.tarotcard-outer:not(.locked) .tarotcard-inner:hover {
				transform: translateY(-40px);
			}
		</style>

		<script>
			// @ts-nocheck
			// https://codepen.io/tkdev-hub/pen/RNGBZMo
			// https://developer.mozilla.org/en-US/docs/Web/API/Pointer_events

			// const cards = document.querySelectorAll(".card");


			const dropzones = document.querySelectorAll(".dropzone");
			const deck = document.querySelector(".cards-container")

			const cards = Array.from({ length: 78 }, (_, i) => ({
			front: `Front ${i + 1}`,
			back: `Back ${i + 1}`
			}));


			let dragged = null;
			let moved = false;
			let lockedCards = new Set();
			let offsetX = 0;
			let offsetY = 0;



			// ----------------------------------------
			// -------- MARK: MAKE TAROT CARDS --------
			// ----------------------------------------
			cards.forEach((card, i) => {
			const button = document.createElement("button");
			
			button.dataset.index = i; 
			
			
			button.className = "tarotcard-outer";
			button.setAttribute("aria-expanded", "false");
			
			button.style.transform = `translateX(${i * 8}px)`;
			button.style.zIndex = i;

			const inner = document.createElement("div");
			inner.className = "tarotcard-inner";

			const front = document.createElement("div");
			front.className = "tarotcard-front";
			front.textContent = card.front;

			const back = document.createElement("div");
			back.className = "tarotcard-back";
			back.textContent = card.back;

			inner.append(front, back);
			button.append(inner);

			deck.appendChild(button);
			
			button.addEventListener("pointerdown", (e) => {
				// Bepalen wat gedragged wordt
				dragged = button;

				// Kijken waar de kaart is en hoe groot hij is
				const rect = button.getBoundingClientRect();

				// Bepalen waar je muis/vinger precies is, zodat hij niet verspringt
				offsetX = e.clientX - rect.left;
				offsetY = e.clientY - rect.top;
				
				button.style.transform = "none";

				// Card wordt uit de flow gehaald. >> De elementen er omheen vullen dat gat ook op.
				document.body.appendChild(button);

				button.style.position = "absolute";
				button.style.left = rect.left + "px";
				button.style.top = rect.top + "px";
				button.style.zIndex = 9999;

				// Zorgt ervoor dat de computer de card blijft volgen, hij plakt nu aan je cursor:
				// https://developer.mozilla.org/en-US/docs/Web/API/PointerEvent/pointerId
				// https://developer.mozilla.org/en-US/docs/Web/API/Element/setPointerCapture
				button.setPointerCapture(e.pointerId);
			});
			
			button.addEventListener("click", rotateTarotcard);
			});




			// -------------------------------------
			// -------- MARK: POINTER MOVER --------
			// -------------------------------------
			document.addEventListener("pointermove", (e) => {
			
			// Checken of er een card gedragged wordt
			if (!dragged) return;
			
			if (lockedCards.has(dragged)) return;
			
			moved = true;
			
			dragged.style.left = (e.clientX - offsetX) + "px";
			dragged.style.top = (e.clientY - offsetY) + "px";
			
			
			const cardRect = dragged.getBoundingClientRect();
			
			
			// Kijken naar afstand tot een dropzone
			dropzones.forEach((zone) => {
				// Locatie en grootte van dropzone
				const zoneRect = zone.getBoundingClientRect();
				
				// ChatGPT!!: hoe bereken ik het midden van mijn dropzone?
				// zoneRect.left: De afstand van de linkerkant van het scherm tot de linkerrand van de zone.
				// zoneRect.width / 2: De helft van de breedte van de zone.
				// Samen: Dit geeft de X-coördinaat van het exacte midden van de dropzone.
				const dx =
				zoneRect.left + zoneRect.width / 2 -
				(cardRect.left + cardRect.width / 2);

				const dy =
				zoneRect.top + zoneRect.height / 2 -
				(cardRect.top + cardRect.height / 2);
				
				// Berekenen hoe veel het midden van de card verwijderd is van het midden van de dropzone     (pythagoras).
				const distance = Math.sqrt(dx * dx + dy * dy);
			
				// Kijken of de dropzone nog leeg is >> .children: lijst van alle elementen die binnenin de zone staan, .length kijkt hoeveel kinderen er zijn daarbinnen >> als gelijk is aan 0 dan is het true dus leeg.
				const isEmpty = zone.children.length === 0;
				
				// Dropzone wordt pas "hot" als de dropzone leeg is EN als de afstand van de kaart tot de dropzone kleiner is dan 180px.
				zone.classList.remove("hot");
				if (isEmpty && distance < 180) {
				zone.classList.add("hot");
				}
				
			});
			
			});



			// ----------------------------------
			// -------- MARK: POINTER UP --------
			// ----------------------------------
			document.addEventListener("pointerup", () => {
			if (!dragged) return;

			const cardRect = dragged.getBoundingClientRect();

			let target = null;

			dropzones.forEach((zone) => {
				const zoneRect = zone.getBoundingClientRect();
				const isEmpty = zone.children.length === 0;
			
				// !! ChatGPT: Hoe zorg ik ervoor dat de computer weet dat de card de dropzone overlapt?
				// >> Dit kijkt of de randen van de kaart de randen van de zone overlappen
				const isInside =
				cardRect.left < zoneRect.right &&
				cardRect.right > zoneRect.left &&
				cardRect.top < zoneRect.bottom &&
				cardRect.bottom > zoneRect.top;
				
				// Als er overlapping is EN de dropzone leeg is, dan wordt die dropzone de target
				if (isInside && isEmpty) {
				target = zone;
				}
			});
			
			// Als het een geldige target heeft gevonden wordt de functie placeInZone aangeroepen.
			if (target) {
				placeInZone(dragged, target);
			} 
			
			
			updateStates();

			// Zorgen dat de dropzone waar de card in komt niet meer hot is als pointer up en target bereikt.
			dropzones.forEach((dropzone) => {
				dropzone.classList.remove("hot");
			})
			
			if (!moved) {
				rotateTarotcard({ currentTarget: dragged });
			}

			moved = false;   // reset
			
			// Zegt dat er geen card meer gedragged wordt.
			dragged = null;
			});



			// -------------------------------------
			// -------- MARK: PLACE IN ZONE --------
			// -------------------------------------
			function placeInZone(card, zone) {
			// Card wordt "kind" van de zone
			zone.appendChild(card);

			const zoneRect = zone.getBoundingClientRect();
			const cardRect = card.getBoundingClientRect();
			
			// !! ChatGPT: Overgebleven ruimte door 2 delen om card te centreren.
			const left = (zoneRect.width - cardRect.width) / 2;
			const top = (zoneRect.height - cardRect.height) / 2;

			card.style.position = "absolute";
			card.style.left = left + "px";
			card.style.top = top + "px";

			card.style.transform = "scale(1.05)";
			
			lockedCards.add(card);
			card.classList.add("locked");
			};


			// -----------------------------------------
			// -------- MARK: ZONE STATE UPDATE --------
			// -----------------------------------------
			function updateStates() {
			
			dropzones.forEach((dropzone) => {
				if (dropzone.children.length === 0) {
				dropzone.classList.remove("full");
				} else {
				dropzone.classList.add("full");
				}
			});
			
			};



			// -----------------------------------
			// -------- MARK: ROTATE CARD --------
			// -----------------------------------
			// https://developer.mozilla.org/en-US/docs/Web/API/Web_Animations_API/Using_the_Web_Animations_API

			function rotateTarotcard(event) {
			const tarotcardInner = event.currentTarget.querySelector(".tarotcard-inner");
			
			// Zodat ik tarotcardOuter later kan gebruiken met aria-expanded attribute (toegankelijkheid).
			const tarotcardOuter = event.currentTarget;
			
			
			if (!tarotcardOuter.parentElement.classList.contains("dropzone")) {
				return;
			}
			
			const tarotcardFlipped = tarotcardInner.dataset.tarotcardFlipped === "true";
			
			tarotcardInner.animate(
				[
				{ transform: tarotcardFlipped ? "rotateY(0deg)" : "rotateY(180deg)" }
				],  
				{
				fill: 'forwards',
				duration: 1500,
				easing: "cubic-bezier(0.34, 1.56, 0.64, 1)"
				}
			);
			
			// tarotcardInner.dataset.tarotcardFlipped = !tarotcardFlipped;
			const newTarotcardState = !tarotcardFlipped;

			tarotcardInner.dataset.tarotcardFlipped = newTarotcardState;

			tarotcardOuter.setAttribute("aria-expanded", newTarotcardState);
			};
		</script>


	</main>

	</body>
</html>