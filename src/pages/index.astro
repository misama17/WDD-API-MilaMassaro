---
// @ts-nocheck
import MainLayout from "../layouts/MainLayout.astro";
import TarotCards from "../components/TarotCards.astro";

const resMeanings = await fetch('https://tarotapi.dev/api/v1/cards')
const tarotMeanings = await resMeanings.json()
---


<MainLayout title="Ask the cards">

	<div class="altar-scene">
		<div class="altar">
			<!-- https://css-tricks.com/abusing-customizable-selects/ -->
			<nav aria-label="Card navigation" class="card-nav">
				<button class="trigger-menu">
					<span>Click on me to see the menu!</span>
					<img src="/assets/images/click.png" alt="Open menu icon">
				</button>

				<a href="/spread" class="card-menu right">
					<span>Do a reading</span>
					<img src="/assets/images/spell-book.png" alt="Do a reading icon">
				</a>
				<a href="/overview" class="card-menu left">
					<span>See a card overview</span>
					<img src="/assets/images/magic-cards.png" alt="See card overview icon">
				</a>
			</nav>
		</div>

		<img src="/assets/images/candle.png" alt="candle" class="candle">
	</div>
	
</MainLayout>

<style>
	.altar-scene {
		display: flex;
		justify-content: center;
		align-items: flex-end;
		perspective: 40em;
		width: 100%;
		height: 90svh;
		margin: 0;
		padding: 0;
	}

    .altar {
		position: relative;
		width: 100%;
		height: 30em;
		background-color: var(--color-object);

		transform:
			rotateX(60deg);

		box-shadow:
			0 8px 20px rgba(0, 0, 0, 0.15),
			0 20px 60px rgba(0, 0, 0, 0.12);
	}

	.card-nav {
		display: grid;
		width: 100vw;
		height: 100svh;
		justify-content: center;
		gap: .5em;
		margin: 10em 0;
	}

	.trigger-menu {
		height: 16em;
		z-index: 3;

		background-color: #4A2852;

		animation: --interval-shaking 2s ease-in-out infinite;
		animation-delay: 5s;

		& img {
			width: 6em;
			align-self: end;
		}

		&:hover {
			animation: --hoverstate-shaking 0.3s ease-in-out;
		}
	}

	.card-menu {
		width: 12em;
		height: 13.3em;
		
		background-color: #6A3F73;

		& img {
			width: 4em;
		}
	}

	.trigger-menu,
	.card-menu {
		grid-area: 1/1;
		display: grid;
		place-content: center;
		
		border: .4em solid #efe7d5;
		border-radius: .25em;

		color: #efe7d5;
		text-align: center;
		text-decoration: none;

		position: relative;
		transform-style: preserve-3d;
		perspective: 12em;

		transition: transform .5s cubic-bezier(0.34, 1.56, 0.64, 1);

		box-shadow:
			inset 0 10px 20px rgba(0,0,0,0.25),  
			inset 0 -10px 20px rgba(255,255,255,0.05),
			0 8px 16px rgba(0, 0, 0, 0.08),
			0 20px 40px rgba(0, 0, 0, 0.12);

		& img {
			object-fit: cover;
			justify-self: center;

			transform: translateZ(1em);
			transition: transform 1s cubic-bezier(0.34, 1.56, 0.64, 1);
		}

		& span {
			margin-top: .75em;
			transform: translateZ(1em);
			transition: transform 1s cubic-bezier(0.34, 1.56, 0.64, 1);
		}

		&:hover {
			& img {
				transform: translateZ(1.2em);
			}

			& span {
				transform: translateZ(1.2em);
			}
		}
	}

	.candle {
		position: absolute;
		z-index: 1;
		bottom: 0;
		height: clamp(35em, 60vw, 45em);
		left: 65%;
		transform: translateX(-50%) translateX(12rem) translateY(-20%);
	}

	/* ChatGPT: shaking cards animation. */
	@keyframes --hoverstate-shaking {
		0%   { transform: translateX(0); }
		25%  { transform: translateX(-3px); }
		50%  { transform: translateX(3px); }
		75%  { transform: translateX(-3px); }
		100% { transform: translateX(0); }
	}

	@keyframes --interval-shaking {
		0%   { transform: translate(0); }

		10%   { transform: translate(-3px); }
		20%  { transform: translate(3px); }
		30%  { transform: translate(-3px); }
		40%  { transform: translate(3px); }

		50% { transform: translate(0); }
		100% { transform: translate(0); }

	}

</style>

<script>
	// @ts-nocheck
	const menuButton = document.querySelector(".trigger-menu");
	const leftNav = document.querySelector(".left");
	const rightNav = document.querySelector(".right");
	const menu = document.querySelector(".card-menu");

	menuButton.addEventListener("click", openMenu);

	function openMenu() {
	// !! ChatGPT
	open = !open;
	
	if (open) {
		rightNav.animate(
		[
			{ transform: "translateX(1em) translateY(.5em) rotatex(15deg)" },
			{ transform: "translateX(13em) translateY(.5em) rotatex(15deg)" }
		],  
		{
			fill: 'forwards',
			duration: 1000,
			easing: "cubic-bezier(0.34, 1.56, 0.64, 1)"
		}
		);
		
		leftNav.animate(
		[
			{ transform: "translateX(1em) translateY(.5em)" },
			{ transform: "translateX(-13em) translateY(.5em)" }
		],  
		{
			fill: 'forwards',
			duration: 1000,
			easing: "cubic-bezier(0.34, 1.56, 0.64, 1)"
		}
		);
	} else if (!open) {
		rightNav.animate(
		[
			{ transform: "translateX(13em) translateY(.5em) rotatex(15deg)" },
			{ transform: "translateX(1em) translateY(.5em) rotatex(15deg)" }
		],  
		{
			fill: 'forwards',
			duration: 1000,
			easing: "cubic-bezier(0.36, 0, 0.66, -0.4)"
		}
		);
		
		leftNav.animate(
		[
			{ transform: "translateX(-13em) translateY(.5em)" },
			{ transform: "translateX(-1em) translateY(.5em)" }
		],  
		{
			fill: 'forwards',
			duration: 1000,
			easing: "cubic-bezier(0.36, 0, 0.66, -0.4)"
		}
		);
	}
	
	};
</script>