---
import MainLayout from "../layouts/MainLayout.astro";
import TarotCards from "../components/TarotCards.astro";

const resMeanings = await fetch('https://tarotapi.dev/api/v1/cards')
const tarotMeanings = await resMeanings.json()
---


<MainLayout title="Ask the cards">

	<div class="altar-scene">
		<div class="altar">
			<!-- https://css-tricks.com/abusing-customizable-selects/ -->
			<nav aria-label="Card navigation" class="card-nav">
				<button class="trigger-menu">Click on me to see the menu!</button>

				<a href="/spread" class="card-menu right">Do a reading</a>
				<a href="/overview" class="card-menu left">See a card overview</a>
			</nav>
		</div>

		<img src="/public/assets/images/candle.png" alt="candle">
	</div>
	
</MainLayout>

<style>
	.altar-scene {
		display: flex;
		justify-content: center;
		align-items: flex-end;
		perspective: 40em;
		width: 100%;
		height: 90svh;
		margin: 0;
		padding: 0;
	}

    .altar {
		position: relative;
		width: 100%;
		height: 30em;
		background-color: var(--color-object);
		transform:
			rotateX(60deg);
		box-shadow:
			0 8px 20px rgba(0, 0, 0, 0.15),
			0 20px 60px rgba(0, 0, 0, 0.12);
	}

	.card-nav {
		display: grid;
		width: 100vw;
		height: 100svh;
		justify-content: center;
		gap: .5em;
		margin: 10em 0;
	}

	.trigger-menu {
		grid-area: 1/1;
		height: 16em;
		background-color: #4A2852;
		border: .45em solid var(--color-border-card);
		z-index: 3;
		border-radius: .25em;

		box-shadow:
			0 8px 16px rgba(0, 0, 0, 0.08),
			0 20px 40px rgba(0, 0, 0, 0.12);
	}

	.card-menu {
		grid-area: 1/1;
		display: grid;
		width: 12em;
		height: 13.3em;
		place-content: center;
		background-color: #6A3F73;
		border: .45em solid var(--color-border-card);
		text-decoration: none;
		border-radius: .25em;

		box-shadow:
			0 8px 16px rgba(0, 0, 0, 0.08),
			0 20px 40px rgba(0, 0, 0, 0.12);

	}

	img {
		position: absolute;
		z-index: 1;
		bottom: 0;
		height: clamp(35em, 60vw, 45em);
		left: 65%;
		transform: translateX(-50%) translateX(12rem) translateY(-20%);
	}


</style>

<script>
	const menuButton = document.querySelector(".trigger-menu");
	const leftNav = document.querySelector(".left");
	const rightNav = document.querySelector(".right");
	const menu = document.querySelector(".card-menu");

	menuButton.addEventListener("click", openMenu);

	function openMenu() {
	open = !open;
	
	if (open) {
		rightNav.animate(
		[
			{ transform: "translateX(1em) translateY(.5em) rotatex(15deg)" },
			{ transform: "translateX(13em) translateY(.5em) rotatex(15deg)" }
		],  
		{
			fill: 'forwards',
			duration: 1000,
			easing: "cubic-bezier(0.34, 1.56, 0.64, 1)"
		}
		);
		
		leftNav.animate(
		[
			{ transform: "translateX(1em) translateY(.5em)" },
			{ transform: "translateX(-13em) translateY(.5em)" }
		],  
		{
			fill: 'forwards',
			duration: 1000,
			easing: "cubic-bezier(0.34, 1.56, 0.64, 1)"
		}
		);
	} else if (!open) {
		rightNav.animate(
		[
			{ transform: "translateX(13em) translateY(.5em) rotatex(15deg)" },
			{ transform: "translateX(1em) translateY(.5em) rotatex(15deg)" }
		],  
		{
			fill: 'forwards',
			duration: 1000,
			easing: "cubic-bezier(0.36, 0, 0.66, -0.4)"
		}
		);
		
		leftNav.animate(
		[
			{ transform: "translateX(-13em) translateY(.5em)" },
			{ transform: "translateX(-1em) translateY(.5em)" }
		],  
		{
			fill: 'forwards',
			duration: 1000,
			easing: "cubic-bezier(0.36, 0, 0.66, -0.4)"
		}
		);
	}
	
	};
</script>