---
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{ title }</title>
    <link rel="stylesheet" href="/public/styles/global.css">
    <link rel="stylesheet" href="/public/styles/typography.css">

  </head>
  <body>
    <h1>{title}</h1>
    <main>
      <slot /> 
    </main>
  </body>
</html>